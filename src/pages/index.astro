---
import Layout from '../layouts/Layout.astro';
const API_BASE = 'http://localhost:8000';
---

<Layout>
	<div id="app">
		<header id="header">
			<div class="header-left">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#171717" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
				<h1>AI Interview Coach</h1>
				<span class="badge">DevOps</span>
			</div>
			<div class="header-right">
				<span id="providerBadge" class="provider-badge hidden"></span>
				<select id="headerModelSelect" class="header-model-select" onchange="onModelChange(this.value)"></select>
				<button id="settingsBtn" class="icon-btn" title="Settings" onclick="toggleSettings()">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
				</button>
			</div>
		</header>

		<div id="settingsPanel" class="settings-panel hidden">
			<div class="settings-inner">
				<h3>Settings</h3>
				<label>AI Provider</label>
				<select id="modelSelect" class="input"></select>
				<label>Answer Length</label>
				<select id="lengthSelect" class="input">
					<option value="short">Short (30-60s)</option>
					<option value="medium" selected>Medium (1-2 min)</option>
					<option value="detailed">Detailed (2-3 min)</option>
				</select>
				<button class="btn btn-secondary btn-sm" onclick="toggleSettings()">Close</button>
			</div>
		</div>

		<div id="mainLayout">
			<aside id="sidebar">
				<div class="sidebar-section">
					<h3>Context</h3>
					<p class="sidebar-hint">Upload your resume and job description to get personalized answers.</p>
				</div>

				<div class="sidebar-section">
					<label class="upload-label">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
						Upload Resume
						<input type="file" accept=".pdf,.docx,.txt" id="resumeInput" onchange="uploadResume(event)" />
					</label>
					<div id="resumeStatus" class="file-status"></div>
					<button id="clearResumeBtn" class="btn-link hidden" onclick="clearResume()">Clear</button>
				</div>

				<div class="sidebar-section">
					<label class="upload-label">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
						Upload Job Description
						<input type="file" accept=".pdf,.docx,.txt" id="jdInput" onchange="uploadJD(event)" />
					</label>
					<div id="jdStatus" class="file-status"></div>
					<button id="clearJDBtn" class="btn-link hidden" onclick="clearJD()">Clear</button>
				</div>

				<div class="sidebar-section sidebar-faq">
					<h3>⭐ Frequently Asked Questions</h3>
					<input id="faqSearch" class="faq-search" type="text" placeholder="Search questions..." oninput="filterFAQ()" />
					<div id="faqList" class="faq-list"></div>
				</div>

				<div class="sidebar-section sidebar-recent">
					<h3>Recent Questions</h3>
					<div id="recentList" class="recent-list"></div>
					<button id="clearHistoryBtn" class="btn-link hidden" onclick="clearHistory()">Clear history</button>
				</div>
			</aside>

			<main id="chatArea">
				<div id="messages"></div>

				<div id="typingIndicator" class="typing-indicator hidden">
					<span></span><span></span><span></span>
					<span class="typing-text">Coaching...</span>
				</div>

				<div id="inputArea">
					<div id="micGroup">
						<button id="micBtn" class="icon-btn mic-btn" onclick="toggleMic()" title="Ask with voice">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
						</button>
						<div id="micStatus" class="mic-status hidden">
							<div class="mic-status-row">
								<span id="listeningLabel" class="listening-label">Listening</span>
								<span id="micLevel" class="mic-level"><span class="mic-level-track"></span></span>
							</div>
							<span id="micTranscript" class="mic-transcript"></span>
						</div>
					</div>
					<textarea id="questionInput" rows="1" placeholder="Ask an interview question..." onkeydown="handleKeyDown(event)"></textarea>
					<button id="sendBtn" class="btn btn-primary btn-send" onclick="sendQuestion()" disabled>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
					</button>
				</div>
			</main>
		</div>
	</div>
</Layout>

<style is:global>
	:root {
		--ink: #171717;
		--canvas: #ffffff;
		--canvas-soft: #fafafa;
		--canvas-soft-2: #f5f5f5;
		--hairline: #ebebeb;
		--hairline-strong: #a1a1a1;
		--body: #4d4d4d;
		--mute: #888888;
		--primary: #171717;
		--on-primary: #ffffff;
		--link: #0070f3;
		--success: #0070f3;
		--error: #ee0000;
		--radius-sm: 6px;
		--radius-md: 8px;
		--radius-lg: 12px;
		--radius-pill: 100px;
	}
	#app {
		display: flex;
		flex-direction: column;
		height: 100vh;
		overflow: hidden;
	}
	#header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
		padding: 0 20px;
		background: var(--canvas);
		border-bottom: 1px solid var(--hairline);
		flex-shrink: 0;
		z-index: 10;
	}
	.header-left {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.header-left h1 {
		font-size: 16px;
		font-weight: 600;
		margin: 0;
		letter-spacing: -0.3px;
	}
	.badge {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		font-weight: 500;
		background: var(--canvas-soft-2);
		color: var(--body);
		padding: 2px 8px;
		border-radius: var(--radius-pill);
		letter-spacing: -0.2px;
	}
	.header-right {
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.provider-badge {
		font-family: 'JetBrains Mono', monospace;
		font-size: 10px;
		font-weight: 500;
		padding: 2px 8px;
		border-radius: var(--radius-pill);
		white-space: nowrap;
		transition: all 0.2s;
	}
	.provider-badge.gemini { background: #e8f5e9; color: #2e7d32; }
	.provider-badge.grok { background: #fff3e0; color: #e65100; }
	.provider-badge.local { background: #e3f2fd; color: #1565c0; }
	.provider-badge.hidden { display: none; }
	.header-model-select {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		height: 28px;
		padding: 0 6px;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-sm);
		background: var(--canvas);
		color: var(--ink);
		cursor: pointer;
		outline: none;
	}
	.header-model-select:focus { border-color: var(--link); }
	.icon-btn {
		width: 34px;
		height: 34px;
		border: 1px solid var(--hairline);
		border-radius: 9999px;
		background: var(--canvas);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--body);
		transition: all 0.15s;
	}
	.icon-btn:hover { background: var(--canvas-soft-2); color: var(--ink); }
	.settings-panel {
		position: fixed;
		top: 56px;
		right: 16px;
		width: 280px;
		background: var(--canvas);
		border: 1px solid var(--hairline);
		border-radius: var(--radius-lg);
		box-shadow: 0 2px 2px rgba(0,0,0,0.05), 0 8px 16px -4px rgba(0,0,0,0.08);
		z-index: 20;
		padding: 20px;
	}
	.settings-panel.hidden { display: none; }
	.settings-inner h3 {
		font-size: 15px;
		font-weight: 600;
		margin: 0 0 16px;
	}
	.settings-inner label {
		display: block;
		font-size: 13px;
		color: var(--body);
		margin: 12px 0 4px;
	}
	.input {
		width: 100%;
		height: 36px;
		padding: 0 10px;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-sm);
		font-size: 13px;
		font-family: inherit;
		background: var(--canvas);
		color: var(--ink);
		outline: none;
	}
	.input:focus { border-color: var(--link); }
	select.input { cursor: pointer; }
	#mainLayout {
		display: flex;
		flex: 1;
		overflow: hidden;
	}
	#sidebar {
		width: 260px;
		flex-shrink: 0;
		background: var(--canvas);
		border-right: 1px solid var(--hairline);
		padding: 16px;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}
	.sidebar-section h3 {
		font-size: 11px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: var(--mute);
		margin: 0 0 8px;
		font-family: 'JetBrains Mono', monospace;
	}
	.sidebar-hint {
		font-size: 13px;
		color: var(--body);
		margin: 0;
		line-height: 1.5;
	}
	.upload-label {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 10px 12px;
		border: 1px dashed var(--hairline-strong);
		border-radius: var(--radius-sm);
		cursor: pointer;
		font-size: 13px;
		color: var(--body);
		transition: all 0.15s;
	}
	.upload-label:hover {
		border-color: var(--link);
		color: var(--link);
		background: #f0f7ff;
	}
	.upload-label input { display: none; }
	.file-status {
		font-size: 11px;
		color: var(--success);
		margin-top: 4px;
	}
	.btn-link {
		background: none;
		border: none;
		color: var(--error);
		font-size: 12px;
		cursor: pointer;
		padding: 2px 0;
	}
	.btn-link.hidden { display: none; }
	.sidebar-recent { border-top: 1px solid var(--hairline); padding-top: 16px; min-height: 0; display: flex; flex-direction: column; }
	.sidebar-faq { flex: 1; min-height: 0; display: flex; flex-direction: column; }
	.faq-search {
		width: 100%;
		padding: 6px 8px;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-sm);
		font-size: 12px;
		font-family: inherit;
		outline: none;
		background: var(--canvas);
		color: var(--ink);
		box-sizing: border-box;
		margin-bottom: 8px;
	}
	.faq-search:focus { border-color: var(--link); }
	.faq-search::placeholder { color: var(--mute); }
	.faq-list {
		flex: 1;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}
	.faq-category {
		border-radius: var(--radius-sm);
		overflow: hidden;
	}
	.faq-category-header {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 6px 8px;
		font-size: 11px;
		font-weight: 600;
		color: var(--body);
		cursor: pointer;
		border-radius: var(--radius-sm);
		transition: background 0.1s;
		user-select: none;
	}
	.faq-category-header:hover { background: var(--canvas-soft-2); }
	.faq-category-header .arrow {
		font-size: 8px;
		transition: transform 0.15s;
	}
	.faq-category-header .arrow.open { transform: rotate(90deg); }
	.faq-category-body {
		display: flex;
		flex-direction: column;
		gap: 1px;
		padding-left: 8px;
	}
	.faq-category-body.hidden { display: none; }
	.faq-item {
		font-size: 12px;
		padding: 5px 8px;
		border-radius: var(--radius-sm);
		cursor: pointer;
		color: var(--body);
		transition: all 0.1s;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.faq-item:hover { background: var(--canvas-soft-2); color: var(--ink); }
	.faq-item.hidden { display: none; }
	.recent-list {
		flex: 1;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.recent-item {
		font-size: 12px;
		padding: 6px 8px;
		border-radius: var(--radius-sm);
		cursor: pointer;
		color: var(--body);
		transition: all 0.1s;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}
	.recent-item:hover { background: var(--canvas-soft-2); color: var(--ink); }
	.recent-item.active { background: var(--canvas-soft-2); color: var(--ink); font-weight: 500; }
	#chatArea {
		flex: 1;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		background: var(--canvas-soft);
	}
	#messages {
		flex: 1;
		overflow-y: auto;
		padding: 20px;
		display: flex;
		flex-direction: column;
		gap: 20px;
	}
	.chat-card {
		display: flex;
		flex-direction: column;
		gap: 10px;
		animation: fadeIn 0.2s ease;
	}
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(8px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.message {
		display: flex;
		gap: 12px;
		max-width: 760px;
	}
	.message.user { align-self: flex-end; flex-direction: row-reverse; }
	.msg-avatar {
		width: 30px;
		height: 30px;
		border-radius: 9999px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.message.assistant .msg-avatar {
		background: var(--primary);
		color: var(--on-primary);
	}
	.message.user .msg-avatar {
		background: var(--canvas-soft-2);
		color: var(--body);
	}
	.msg-content {
		background: var(--canvas);
		border: 1px solid var(--hairline);
		border-radius: var(--radius-lg);
		padding: 12px 16px;
		font-size: 14px;
		line-height: 1.6;
		color: var(--ink);
		overflow-x: auto;
	}
	.message.user .msg-content {
		background: var(--primary);
		color: var(--on-primary);
		border-color: var(--primary);
	}
	.msg-content p { margin: 0 0 6px; }
	.msg-content p:last-child { margin: 0; }
	.msg-content strong { font-weight: 600; }
	.streaming-cursor {
		display: inline-block;
		animation: blink 0.8s step-end infinite;
		color: var(--mute);
		font-weight: 300;
	}
	@keyframes blink { 50% { opacity: 0; } }
	.msg-actions {
		display: flex;
		gap: 4px;
		margin-top: 8px;
		flex-wrap: wrap;
	}
	.msg-action-btn {
		background: none;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-sm);
		padding: 3px 8px;
		font-size: 11px;
		color: var(--mute);
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 4px;
		transition: all 0.1s;
		font-family: inherit;
	}
	.msg-action-btn:hover { color: var(--ink); border-color: var(--hairline-strong); background: var(--canvas-soft); }
	.msg-action-btn.primary-action { color: var(--link); border-color: var(--link); }
	.msg-action-btn.primary-action:hover { background: #f0f7ff; }
	.msg-action-btn.stop-btn { color: var(--error); border-color: var(--error); }
	.msg-action-btn.stop-btn:hover { background: var(--error); color: white; }
	.card-interrupted .msg-content { opacity: 0.6; border-style: dashed; }
	.typing-indicator {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 8px 20px;
	}
	.typing-indicator.hidden { display: none; }
	.typing-indicator span {
		width: 6px; height: 6px;
		border-radius: 50%;
		background: var(--hairline-strong);
		animation: bounce 1.2s infinite;
	}
	.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
	.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
	@keyframes bounce {
		0%, 60%, 100% { transform: translateY(0); }
		30% { transform: translateY(-4px); }
	}
	.typing-text {
		font-size: 12px;
		color: var(--mute);
		margin-left: 4px;
		font-family: 'JetBrains Mono', monospace;
	}
	#inputArea {
		display: flex;
		align-items: flex-end;
		gap: 8px;
		padding: 12px 20px 16px;
		background: var(--canvas);
		border-top: 1px solid var(--hairline);
	}
	#questionInput {
		flex: 1;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-md);
		padding: 10px 14px;
		font-size: 14px;
		font-family: inherit;
		line-height: 1.4;
		resize: none;
		outline: none;
		background: var(--canvas-soft);
		color: var(--ink);
		max-height: 120px;
		min-height: 42px;
	}
	#questionInput:focus { border-color: var(--ink); }
	#questionInput::placeholder { color: var(--mute); }
	#micGroup {
		display: flex;
		align-items: center;
		gap: 6px;
		flex-shrink: 0;
	}
	.mic-btn {
		width: 42px;
		height: 42px;
		flex-shrink: 0;
	}
	.mic-btn.listening {
		background: var(--error);
		color: white;
		border-color: var(--error);
		animation: pulse 1.2s infinite;
	}
	.mic-status {
		display: flex;
		flex-direction: column;
		gap: 2px;
		animation: fadeIn 0.2s ease;
	}
	.mic-status.hidden { display: none; }
	.mic-status-row {
		display: flex;
		align-items: center;
		gap: 8px;
	}
	.listening-label {
		font-size: 11px;
		font-weight: 600;
		color: var(--error);
		white-space: nowrap;
	}
	.mic-level {
		display: flex;
		align-items: center;
		gap: 1px;
		height: 14px;
	}
	.mic-level-track {
		display: flex;
		align-items: flex-end;
		gap: 1px;
		height: 14px;
	}
	.mic-level-track .bar {
		width: 2px;
		background: var(--error);
		border-radius: 1px;
		transition: height 0.05s ease;
		min-height: 2px;
	}
	.mic-level-track .bar.active { opacity: 1; }
	.mic-level-track .bar.mid { opacity: 0.6; }
	.mic-level-track .bar.low { opacity: 0.3; }
	.mic-transcript {
		font-size: 11px;
		color: var(--mute);
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		max-width: 280px;
		min-height: 14px;
		line-height: 1.3;
	}
	.mic-transcript.highlight { color: var(--ink); font-style: italic; }
	@keyframes pulse {
		0%, 100% { box-shadow: 0 0 0 0 rgba(238,0,0,0.4); }
		50% { box-shadow: 0 0 0 8px rgba(238,0,0,0); }
	}
	.btn {
		font-family: inherit;
		cursor: pointer;
		border: none;
		font-weight: 500;
		transition: all 0.15s;
	}
	.btn-primary {
		background: var(--primary);
		color: var(--on-primary);
		border-radius: var(--radius-pill);
	}
	.btn-primary:hover { opacity: 0.85; }
	.btn-primary:disabled { opacity: 0.3; cursor: not-allowed; }
	.btn-secondary {
		background: var(--canvas);
		color: var(--ink);
		border: 1px solid var(--hairline);
		border-radius: var(--radius-sm);
	}
	.btn-secondary:hover { background: var(--canvas-soft-2); }
	.btn-sm { padding: 6px 14px; font-size: 13px; }
	.btn-send {
		width: 42px;
		height: 42px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	@media (max-width: 768px) {
		#sidebar { display: none; }
	}
</style>

<script is:inline>
const API_BASE = 'http://localhost:8000';
let sessionId = 'default';
let isListening = false;
let currentSpeaker = null;
let abortController = null;
let userScrolled = false;
let recentQuestions = [];
let messageCounter = 0;

const STORAGE_KEYS = {
	RECENT: 'interview_coach_recent',
	MODEL: 'interview_coach_model',
	LENGTH: 'interview_coach_length',
	RESUME: 'interview_coach_resume',
	JD: 'interview_coach_jd',
};

const messagesEl = document.getElementById('messages');
const questionInput = document.getElementById('questionInput');
const sendBtn = document.getElementById('sendBtn');
const typingEl = document.getElementById('typingIndicator');
const micBtn = document.getElementById('micBtn');
const providerBadge = document.getElementById('providerBadge');

function setActiveProvider(name) {
	const label = name || '';
	providerBadge.textContent = label ? `Using ${label}` : '';
	providerBadge.className = 'provider-badge';
	if (label) {
		const cls = label.toLowerCase().includes('gemini') ? 'gemini'
			: label.toLowerCase().includes('grok') ? 'grok'
			: label.toLowerCase().includes('local') ? 'local'
			: '';
		if (cls) providerBadge.classList.add(cls);
		providerBadge.classList.remove('hidden');
	} else {
		providerBadge.classList.add('hidden');
	}
}

function saveToStorage(key, value) {
	try { localStorage.setItem(key, JSON.stringify(value)); } catch (e) {}
}

function loadFromStorage(key, fallback) {
	try {
		const v = localStorage.getItem(key);
		return v ? JSON.parse(v) : fallback;
	} catch (e) { return fallback; }
}

messagesEl.addEventListener('scroll', () => {
	const atBottom = messagesEl.scrollHeight - messagesEl.scrollTop - messagesEl.clientHeight < 80;
	userScrolled = !atBottom;
});

function scrollToBottom(smooth) {
	if (userScrolled) return;
	messagesEl.scrollTo({ top: messagesEl.scrollHeight, behavior: smooth ? 'smooth' : 'auto' });
}

function getApiBase() { return API_BASE; }
function getModel() { return document.getElementById('headerModelSelect')?.value || ''; }
function getLength() { return document.getElementById('lengthSelect')?.value || 'medium'; }

function syncModelSelects(value) {
	document.getElementById('headerModelSelect').value = value;
	document.getElementById('modelSelect').value = value;
	saveToStorage(STORAGE_KEYS.MODEL, value);
}

function onModelChange(value) {
	syncModelSelects(value);
}

async function loadModels() {
	const headerSel = document.getElementById('headerModelSelect');
	const settingsSel = document.getElementById('modelSelect');
	const savedModel = loadFromStorage(STORAGE_KEYS.MODEL, null);
	try {
		const resp = await fetch(`${getApiBase()}/api/models`);
		const data = await resp.json();
		headerSel.innerHTML = '';
		settingsSel.innerHTML = '';
		for (const m of data.models) {
			const badges = (m.badges || []).map(b => b === 'fast' ? '⚡' : b === 'local' ? '💻' : '☁️').join(' ');
			const label = `${badges ? badges + ' ' : ''}${m.name}`;
			const hOpt = document.createElement('option');
			hOpt.value = m.id; hOpt.textContent = label;
			headerSel.appendChild(hOpt);
			const sOpt = document.createElement('option');
			sOpt.value = m.id; sOpt.textContent = label;
			settingsSel.appendChild(sOpt);
		}
		const defaultModel = savedModel || data.default;
		if (defaultModel && headerSel.querySelector(`option[value="${defaultModel}"]`)) {
			syncModelSelects(defaultModel);
		}
	} catch (e) {
		headerSel.innerHTML = '<option value="">No models</option>';
		settingsSel.innerHTML = '<option value="">No models available</option>';
	}
}

const savedLength = loadFromStorage(STORAGE_KEYS.LENGTH, 'medium');
document.getElementById('lengthSelect').value = savedLength;
document.getElementById('lengthSelect').addEventListener('change', () => {
	saveToStorage(STORAGE_KEYS.LENGTH, document.getElementById('lengthSelect').value);
});

questionInput.addEventListener('input', () => {
	sendBtn.disabled = !questionInput.value.trim();
	autoResize(questionInput);
});

function autoResize(el) {
	el.style.height = 'auto';
	el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function handleKeyDown(e) {
	if (e.key === 'Enter' && !e.shiftKey) {
		e.preventDefault();
		sendQuestion();
	}
}

function escapeHtml(text) {
	const div = document.createElement('div');
	div.textContent = text;
	return div.innerHTML;
}

function formatMessage(text) {
	let html = escapeHtml(text);
	html = html
		.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
		.replace(/\n/g, '<br/>');
	return `<p>${html}</p>`;
}

function createChatCard(question) {
	const card = document.createElement('div');
	card.className = 'chat-card';
	card.dataset.index = messageCounter++;

	const userMsg = document.createElement('div');
	userMsg.className = 'message user';
	userMsg.innerHTML = `<div class="msg-avatar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div><div class="msg-content"><p>${escapeHtml(question)}</p></div>`;

	const assistantMsg = document.createElement('div');
	assistantMsg.className = 'message assistant';
	const avatar = document.createElement('div');
	avatar.className = 'msg-avatar';
	avatar.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>';
	const contentDiv = document.createElement('div');
	contentDiv.className = 'msg-content';
	contentDiv.innerHTML = '<span class="streaming-cursor">|</span>';
	assistantMsg.appendChild(avatar);
	assistantMsg.appendChild(contentDiv);

	card.appendChild(userMsg);
	card.appendChild(assistantMsg);
	messagesEl.appendChild(card);

	return { card, contentEl: contentDiv };
}

function updateStreamingBubble(contentEl, text) {
	contentEl.innerHTML = formatMessage(text) + '<span class="streaming-cursor">|</span>';
}

function addStopButton(contentEl, onStop) {
	const actions = document.createElement('div');
	actions.className = 'msg-actions';
	const stopBtn = document.createElement('button');
	stopBtn.className = 'msg-action-btn stop-btn';
	stopBtn.innerHTML = '⏹ Stop';
	stopBtn.onclick = onStop;
	actions.appendChild(stopBtn);
	contentEl.appendChild(actions);
}

function finalizeAnswer(contentEl, text) {
	contentEl.innerHTML = formatMessage(text);
	const actions = document.createElement('div');
	actions.className = 'msg-actions';

	const speakBtn = document.createElement('button');
	speakBtn.className = 'msg-action-btn';
	speakBtn.dataset.speaking = 'false';
	speakBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
	speakBtn.onclick = () => toggleSpeech(speakBtn, text.replace(/<[^>]*>/g, ''));

	const copyBtn = document.createElement('button');
	copyBtn.className = 'msg-action-btn';
	copyBtn.innerHTML = '📋 Copy';
	copyBtn.onclick = () => {
		navigator.clipboard.writeText(text.replace(/<[^>]*>/g, '')).then(() => {
			copyBtn.textContent = '✓ Copied';
			setTimeout(() => { copyBtn.innerHTML = '📋 Copy'; }, 2000);
		});
	};

	const retryBtn = document.createElement('button');
	retryBtn.className = 'msg-action-btn primary-action';
	retryBtn.innerHTML = '🔄 Try Again';
	retryBtn.onclick = () => regenerateAnswer(contentEl.closest('.chat-card'), contentEl);

	actions.appendChild(speakBtn);
	actions.appendChild(copyBtn);
	actions.appendChild(retryBtn);
	contentEl.appendChild(actions);
}

function addRecentQuestion(text) {
	recentQuestions = recentQuestions.filter(q => q !== text);
	recentQuestions.unshift(text);
	if (recentQuestions.length > 20) recentQuestions = recentQuestions.slice(0, 20);
	saveToStorage(STORAGE_KEYS.RECENT, recentQuestions);
	renderRecentList();
}

function renderRecentList() {
	const list = document.getElementById('recentList');
	const clearBtn = document.getElementById('clearHistoryBtn');
	list.innerHTML = '';
	if (recentQuestions.length === 0) {
		list.innerHTML = '<p style="font-size:12px;color:var(--mute);margin:0">No questions yet.</p>';
		clearBtn.classList.add('hidden');
		return;
	}
	clearBtn.classList.remove('hidden');
	for (const q of recentQuestions) {
		const item = document.createElement('div');
		item.className = 'recent-item';
		item.textContent = q;
		item.onclick = () => {
			questionInput.value = q;
			sendBtn.disabled = false;
			autoResize(questionInput);
			sendQuestion(q);
		};
		list.appendChild(item);
	}
}

function clearHistory() {
	recentQuestions = [];
	saveToStorage(STORAGE_KEYS.RECENT, []);
	renderRecentList();
	messagesEl.innerHTML = '';
	messageCounter = 0;
	addWelcomeMessage();
}

function addWelcomeMessage() {
	const card = document.createElement('div');
	card.className = 'chat-card welcome-card';
	const msg = document.createElement('div');
	msg.className = 'message assistant';
	msg.innerHTML = `<div class="msg-avatar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg></div><div class="msg-content"><p>Hi! I'm your DevOps Interview Answer Coach. Upload your resume and job description for personalized answers, then ask me any interview question to get started.</p></div>`;
	card.appendChild(msg);
	messagesEl.appendChild(card);
}

async function sendQuestion(text) {
	const q = text || questionInput.value.trim();
	if (!q) return;

	if (abortController) {
		abortController.abort();
		abortController = null;
	}

	const activeCard = messagesEl.querySelector('.chat-card:last-child .message.assistant .streaming-cursor');
	if (activeCard) {
		activeCard.closest('.chat-card')?.classList.add('card-interrupted');
	}

	abortController = new AbortController();
	const signal = abortController.signal;

	questionInput.value = '';
	autoResize(questionInput);
	sendBtn.disabled = true;

	setActiveProvider('');
	userScrolled = false;

	addRecentQuestion(q);

	const { card, contentEl } = createChatCard(q);
	scrollToBottom(false);

	addStopButton(contentEl, () => {
		if (abortController) {
			abortController.abort();
			abortController = null;
		}
	});

	try {
		const resp = await fetch(`${getApiBase()}/api/ask`, {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				question: q,
				session_id: sessionId,
				model: getModel(),
				length: getLength(),
			}),
			signal,
		});

		const reader = resp.body.getReader();
		const decoder = new TextDecoder();
		let buffer = '';
		let fullAnswer = '';

		while (true) {
			const { done, value } = await reader.read();
			if (done) break;

			buffer += decoder.decode(value, { stream: true });
			const lines = buffer.split('\n');
			buffer = lines.pop() || '';

			for (const line of lines) {
				const trimmed = line.trim();
				if (!trimmed.startsWith('data: ')) continue;
				const payload = trimmed.slice(6);
				if (payload === '[DONE]') continue;
				try {
					const parsed = JSON.parse(payload);
					if (parsed.provider) {
						setActiveProvider(parsed.provider);
					} else if (parsed.token) {
						fullAnswer += parsed.token;
						updateStreamingBubble(contentEl, fullAnswer);
					} else if (parsed.error) {
						contentEl.innerHTML = `<p>${escapeHtml(parsed.error)}</p>`;
					}
				} catch (e) {}
			}
		}

		contentEl.querySelector('.msg-actions')?.remove();
		if (fullAnswer) {
			finalizeAnswer(contentEl, fullAnswer);
		}
	} catch (err) {
		if (err.name === 'AbortError') {
			contentEl.querySelector('.msg-actions')?.remove();
			card.classList.add('card-interrupted');
			if (contentEl.textContent.trim() === '|' || contentEl.textContent.trim() === '') {
				contentEl.innerHTML = '<p style="color:var(--mute);font-size:13px">Stopped.</p>';
			}
			return;
		}
		contentEl.innerHTML = `<p>Connection error. Make sure the backend is running.</p>`;
	}

	abortController = null;
}

async function regenerateAnswer(card, oldContentEl) {
	const userMsgEl = card?.querySelector('.message.user .msg-content');
	if (!userMsgEl) return;
	const question = userMsgEl.textContent || '';
	card.remove();
	await sendQuestion(question);
}

function askQuick(text) {
	sendQuestion(text);
}

function toggleSpeech(btn, text) {
	if (!window.speechSynthesis) return;
	const isSpeaking = btn.dataset.speaking === 'true';

	if (isSpeaking) {
		window.speechSynthesis.cancel();
		btn.dataset.speaking = 'false';
		btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
		currentSpeaker = null;
		return;
	}

	if (currentSpeaker) {
		currentSpeaker.dataset.speaking = 'false';
		currentSpeaker.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
		window.speechSynthesis.cancel();
	}

	const speech = text.slice(0, 2000);
	const utterance = new SpeechSynthesisUtterance(speech);
	utterance.rate = 1.0;
	utterance.pitch = 1.0;

	const voices = window.speechSynthesis.getVoices();
	const preferred = voices.find(v => v.lang.startsWith('en') && v.name.includes('Google'));
	if (preferred) utterance.voice = preferred;

	utterance.onend = () => {
		btn.dataset.speaking = 'false';
		btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
		currentSpeaker = null;
	};

	window.speechSynthesis.speak(utterance);
	btn.dataset.speaking = 'true';
	btn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg> Stop';
	currentSpeaker = btn;
}

async function uploadResume(e) {
	const file = e.target.files[0];
	if (!file) return;
	const formData = new FormData();
	formData.append('file', file);
	formData.append('session_id', sessionId);
	try {
		const resp = await fetch(`${getApiBase()}/api/upload/resume?session_id=${sessionId}`, { method: 'POST', body: formData });
		const data = await resp.json();
		if (data.status === 'ok') {
			document.getElementById('resumeStatus').textContent = 'Resume uploaded';
			document.getElementById('clearResumeBtn').classList.remove('hidden');
			saveToStorage(STORAGE_KEYS.RESUME, { filename: file.name, preview: data.preview });
		}
	} catch (err) {
		document.getElementById('resumeStatus').textContent = 'Upload failed';
	}
}

