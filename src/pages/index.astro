function renderFAQ(filter) {
	const list = document.getElementById('faqList');
	list.innerHTML = '';
	const f = (filter || '').toLowerCase().trim();
	for (const cat of FAQ_DATA) {
		const catDiv = document.createElement('div');
		catDiv.className = 'faq-category';

		const header = document.createElement('div');
		header.className = 'faq-category-header';
		header.innerHTML = `<span class="arrow open">▶</span> ${cat.label}`;
		const body = document.createElement('div');
		body.className = 'faq-category-body';

		let visibleCount = 0;
		for (const q of cat.questions) {
			const item = document.createElement('div');
			item.className = 'faq-item';
			item.textContent = q;
			const match = !f || q.toLowerCase().includes(f);
			if (!match) item.classList.add('hidden');
			else visibleCount++;
			item.onclick = () => {
				if (abortController) { abortController.abort(); abortController = null; }
				const existing = messagesEl.querySelector('.chat-card:last-child .message.assistant .streaming-cursor');
				if (existing) existing.closest('.chat-card')?.classList.add('card-interrupted');
				sendQuestion(q);
			};
			body.appendChild(item);
		}

		if (f && visibleCount === 0) {
			catDiv.classList.add('hidden');
		} else {
			catDiv.classList.remove('hidden');
		}

		if (f) {
			body.classList.remove('hidden');
			header.querySelector('.arrow').classList.add('open');
		} else {
			const saved = sessionStorage.getItem('faq_open_' + cat.label);
			if (saved === '1') {
				body.classList.remove('hidden');
				header.querySelector('.arrow').classList.add('open');
			}
		}

		header.onclick = () => {
			body.classList.toggle('hidden');
			header.querySelector('.arrow').classList.toggle('open');
			sessionStorage.setItem('faq_open_' + cat.label, body.classList.contains('hidden') ? '0' : '1');
		};

		catDiv.appendChild(header);
		catDiv.appendChild(body);
		list.appendChild(catDiv);
	}
}

function filterFAQ() {
	const q = document.getElementById('faqSearch').value;
	renderFAQ(q);
}

