function toggleSettings() {
	document.getElementById('settingsPanel').classList.toggle('hidden');
}

const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
let recognition = null;
let silenceTimer = null;
let finalTranscript = '';
let micManuallyStopped = false;
let micStream = null;
let audioContext = null;
let analyserNode = null;
let animationId = null;

async function preloadMic() {
	try {
		micStream = await navigator.mediaDevices.getUserMedia({
			audio: {
				echoCancellation: true,
				noiseSuppression: true,
				autoGainControl: true,
				channelCount: 1,
				sampleRate: 16000,
			},
		});
		audioContext = new (window.AudioContext || window.webkitAudioContext)();
		const source = audioContext.createMediaStreamSource(micStream);
		analyserNode = audioContext.createAnalyser();
		analyserNode.fftSize = 256;
		source.connect(analyserNode);
	} catch (e) {
		console.warn('Mic preload failed, will request on demand:', e.message);
	}
}

preloadMic();

if (SpeechRecognition) {
	recognition = new SpeechRecognition();
	recognition.lang = 'en-US';
	recognition.interimResults = true;
	recognition.continuous = false;
	recognition.maxAlternatives = 3;

	recognition.onresult = (event) => {
		clearTimeout(silenceTimer);
		let interim = '';
		finalTranscript = '';
		let bestConfidence = 0;
		for (let i = event.resultIndex; i < event.results.length; i++) {
			const result = event.results[i];
			const alt = result[0];
			if (alt.confidence > bestConfidence) bestConfidence = alt.confidence;
			if (result.isFinal) finalTranscript += alt.transcript;
			else interim += alt.transcript;
		}
		const displayText = finalTranscript + interim;
		questionInput.value = displayText;
		sendBtn.disabled = false;
		autoResize(questionInput);
		const micTranscript = document.getElementById('micTranscript');
		if (micTranscript) micTranscript.textContent = interim || (finalTranscript ? finalTranscript : '');

		if (finalTranscript && finalTranscript.trim().length > 1) {
			if (bestConfidence < 0.3 && bestConfidence > 0) {
				if (micTranscript) {
					micTranscript.textContent = 'I couldn\'t hear you clearly. Please try again or move closer to the microphone.';
					micTranscript.classList.add('highlight');
				}
				setTimeout(() => {
					finalTranscript = '';
					questionInput.value = '';
					sendBtn.disabled = true;
					autoResize(questionInput);
					if (micTranscript) {
						micTranscript.textContent = '';
						micTranscript.classList.remove('highlight');
					}
				}, 2000);
				return;
			}
			silenceTimer = setTimeout(() => { if (recognition) recognition.stop(); }, 1500);
		}
	};

	recognition.onstart = () => {
		micBtn.classList.add('listening');
		document.getElementById('micStatus').classList.remove('hidden');
		isListening = true;
		micManuallyStopped = false;
		finalTranscript = '';
		const mt = document.getElementById('micTranscript');
		if (mt) { mt.textContent = ''; mt.classList.remove('highlight'); }
		startLevelMeter();
	};

	recognition.onerror = (e) => {
		micBtn.classList.remove('listening');
		document.getElementById('micStatus').classList.add('hidden');
		isListening = false;
		clearTimeout(silenceTimer);
		stopLevelMeter();
	};

	recognition.onend = () => {
		micBtn.classList.remove('listening');
		document.getElementById('micStatus').classList.add('hidden');
		isListening = false;
		clearTimeout(silenceTimer);
		stopLevelMeter();
		if (finalTranscript && !micManuallyStopped) {
			questionInput.value = finalTranscript;
			sendBtn.disabled = false;
			autoResize(questionInput);
			sendQuestion(finalTranscript);
		}
		finalTranscript = '';
		micManuallyStopped = false;
	};
}

function startLevelMeter() {
	stopLevelMeter();
	const track = document.querySelector('.mic-level-track');
	if (!track || !analyserNode) return;
	const bars = track.querySelectorAll('.bar');
	if (!bars.length) {
		for (let i = 0; i < 12; i++) {
			const bar = document.createElement('span');
			bar.className = 'bar' + (i < 4 ? ' low' : i < 8 ? ' mid' : ' active');
			track.appendChild(bar);
		}
	}
	const dataArray = new Uint8Array(analyserNode.frequencyBinCount);
	function tick() {
		if (!isListening) return;
		analyserNode.getByteTimeDomainData(dataArray);
		let sum = 0;
		for (let i = 0; i < dataArray.length; i++) {
			const val = dataArray[i] - 128;
			sum += val * val;
		}
		const rms = Math.sqrt(sum / dataArray.length);
		const level = Math.min(1, rms / 60);
		const numBars = Math.round(level * 12);
		const bars = track.querySelectorAll('.bar');
		bars.forEach((b, i) => {
			b.style.height = (2 + (i + 1) * 1.2) + 'px';
			b.style.opacity = i < numBars ? '1' : '0.15';
		});
		animationId = requestAnimationFrame(tick);
	}
	animationId = requestAnimationFrame(tick);
}

function stopLevelMeter() {
	if (animationId) {
		cancelAnimationFrame(animationId);
		animationId = null;
	}
}

function toggleMic() {
	if (isListening) return stopListening();
	startListening();
}

function startListening() {
	if (!recognition) {
		const card = messagesEl.querySelector('.chat-card:last-child .message.assistant .streaming-cursor');
		if (!card) {
			const c = document.createElement('div');
			c.className = 'chat-card';
			const m = document.createElement('div');
			m.className = 'message assistant';
			m.innerHTML = '<div class="msg-avatar"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg></div><div class="msg-content"><p>Voice input is not supported in this browser. Try Chrome or Edge.</p></div>';
			c.appendChild(m);
			messagesEl.appendChild(c);
		}
		return;
	}

	if (abortController) {
		abortController.abort();
		abortController = null;
	}
	window.speechSynthesis?.cancel();
	if (currentSpeaker) {
		currentSpeaker.dataset.speaking = 'false';
		currentSpeaker.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
		currentSpeaker = null;
	}

	if (!micStream) preloadMic();

	finalTranscript = '';
	questionInput.value = '';
	sendBtn.disabled = true;
	autoResize(questionInput);
	try { if (recognition) recognition.start(); } catch (e) {}
}

function stopListening() {
	clearTimeout(silenceTimer);
	micManuallyStopped = true;
	if (recognition) { try { recognition.stop(); } catch (e) {} }
	micBtn.classList.remove('listening');
	document.getElementById('micStatus').classList.add('hidden');
	isListening = false;
	stopLevelMeter();
}

