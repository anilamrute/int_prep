---
import Layout from '../layouts/Layout.astro';
const API_BASE = 'http://localhost:8000';
---

<Layout>
	<div id="app">
		<header id="header">
			<div class="header-left">
				<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#171717" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
				<h1>AI Interview Coach</h1>
				<span class="badge">DevOps</span>
			</div>
			<div class="header-right">
				<button id="settingsBtn" class="icon-btn" title="Settings" onclick="toggleSettings()">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
				</button>
			</div>
		</header>

		<div id="settingsPanel" class="settings-panel hidden">
			<div class="settings-inner">
				<h3>Settings</h3>
				<label>API Base URL</label>
				<input id="apiBaseInput" type="text" value="http://localhost:8000" class="input" />
				<label>AI Model</label>
				<select id="modelSelect" class="input">
					<option value="llama-3.3-70b-versatile">Llama 3.3 70B</option>
					<option value="llama-3.1-8b-instant">Llama 3.1 8B</option>
					<option value="qwen/qwen3-32b">Qwen 3 32B</option>
				</select>
				<label>Answer Style</label>
				<select id="styleSelect" class="input">
					<option value="natural">Natural (Default)</option>
					<option value="concise">Concise</option>
					<option value="detailed">Detailed</option>
					<option value="beginner">Beginner-Friendly</option>
				</select>
				<button class="btn btn-secondary btn-sm" onclick="toggleSettings()">Close</button>
			</div>
		</div>

		<div id="mainLayout">
			<aside id="sidebar">
				<div class="sidebar-section">
					<h3>Context</h3>
					<p class="sidebar-hint">Upload your resume and job description to get personalized answers.</p>
				</div>

				<div class="sidebar-section">
					<label class="upload-label">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
						Upload Resume
						<input type="file" accept=".pdf,.docx,.txt" id="resumeInput" onchange="uploadResume(event)" />
					</label>
					<div id="resumeStatus" class="file-status"></div>
					<button id="clearResumeBtn" class="btn-link hidden" onclick="clearResume()">Clear</button>
				</div>

				<div class="sidebar-section">
					<label class="upload-label">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
						Upload Job Description
						<input type="file" accept=".pdf,.docx,.txt" id="jdInput" onchange="uploadJD(event)" />
					</label>
					<div id="jdStatus" class="file-status"></div>
					<button id="clearJDBtn" class="btn-link hidden" onclick="clearJD()">Clear</button>
				</div>

				<div class="sidebar-section sidebar-tips">
					<h3>Sample Questions</h3>
					<div class="tip-chips">
						<button class="chip" onclick="askQuick('Tell me about yourself')">Tell me about yourself</button>
						<button class="chip" onclick="askQuick('Explain your Kubernetes experience')">Explain your Kubernetes experience</button>
						<button class="chip" onclick="askQuick('Describe a production incident you handled')">Production incident you handled</button>
						<button class="chip" onclick="askQuick('Explain blue-green deployment')">Blue-green deployment</button>
						<button class="chip" onclick="askQuick('How do you troubleshoot failing pods?')">Troubleshoot failing pods</button>
						<button class="chip" onclick="askQuick('Explain CI/CD pipelines')">CI/CD pipelines</button>
						<button class="chip" onclick="askQuick('What happens when a node becomes NotReady?')">Node NotReady</button>
						<button class="chip" onclick="askQuick('Give me a STAR answer for a time you reduced downtime')">STAR: Reduced downtime</button>
					</div>
				</div>
			</aside>

			<main id="chatArea">
				<div id="messages">
					<div class="message assistant">
						<div class="msg-avatar">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
						</div>
						<div class="msg-content">
							<p>Hi! I'm your DevOps Interview Answer Coach. Upload your resume and job description for personalized answers, then ask me any interview question to get started.</p>
						</div>
					</div>
				</div>

				<div id="typingIndicator" class="typing-indicator hidden">
					<span></span><span></span><span></span>
					<span class="typing-text">Coaching...</span>
				</div>

				<div id="inputArea">
					<div id="micGroup">
						<button id="micBtn" class="icon-btn mic-btn" onclick="toggleMic()" title="Ask with voice">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>
						</button>
						<span id="listeningLabel" class="listening-label hidden">Listening...</span>
					</div>
					<textarea id="questionInput" rows="1" placeholder="Ask an interview question..." onkeydown="handleKeyDown(event)"></textarea>
					<button id="sendBtn" class="btn btn-primary btn-send" onclick="sendQuestion()" disabled>
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
					</button>
				</div>
			</main>
		</div>
	</div>
</Layout>

<style is:global>
	:root {
		--ink: #171717;
		--canvas: #ffffff;
		--canvas-soft: #fafafa;
		--canvas-soft-2: #f5f5f5;
		--hairline: #ebebeb;
		--hairline-strong: #a1a1a1;
		--body: #4d4d4d;
		--mute: #888888;
		--primary: #171717;
		--on-primary: #ffffff;
		--link: #0070f3;
		--success: #0070f3;
		--error: #ee0000;
		--radius-sm: 6px;
		--radius-md: 8px;
		--radius-lg: 12px;
		--radius-pill: 100px;
	}
	#app {
		display: flex;
		flex-direction: column;
		height: 100vh;
		overflow: hidden;
	}
	#header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 56px;
		padding: 0 20px;
		background: var(--canvas);
		border-bottom: 1px solid var(--hairline);
		flex-shrink: 0;
		z-index: 10;
	}
	.header-left {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.header-left h1 {
		font-size: 16px;
		font-weight: 600;
		margin: 0;
		letter-spacing: -0.3px;
	}
	.badge {
		font-family: 'JetBrains Mono', monospace;
		font-size: 11px;
		font-weight: 500;
		background: var(--canvas-soft-2);
		color: var(--body);
		padding: 2px 8px;
		border-radius: var(--radius-pill);
		letter-spacing: -0.2px;
	}
	.header-right {
		display: flex;
		gap: 8px;
	}
	.icon-btn {
		width: 34px;
		height: 34px;
		border: 1px solid var(--hairline);
		border-radius: 9999px;
		background: var(--canvas);
		cursor: pointer;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--body);
		transition: all 0.15s;
	}
	.icon-btn:hover {
		background: var(--canvas-soft-2);
		color: var(--ink);
	}
	.settings-panel {
		position: fixed;
		top: 56px;
		right: 16px;
		width: 320px;
		background: var(--canvas);
		border: 1px solid var(--hairline);
		border-radius: var(--radius-lg);
		box-shadow: 0 2px 2px rgba(0,0,0,0.05), 0 8px 16px -4px rgba(0,0,0,0.08);
		z-index: 20;
		padding: 20px;
	}
	.settings-panel.hidden { display: none; }
	.settings-inner h3 {
		font-size: 15px;
		font-weight: 600;
		margin: 0 0 16px;
	}
	.settings-inner label {
		display: block;
		font-size: 13px;
		color: var(--body);
		margin: 12px 0 4px;
	}
	.input {
		width: 100%;
		height: 36px;
		padding: 0 10px;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-sm);
		font-size: 13px;
		font-family: inherit;
		background: var(--canvas);
		color: var(--ink);
		outline: none;
	}
	.input:focus { border-color: var(--link); }
	select.input { cursor: pointer; }
	.toggle-row {
		display: flex;
		align-items: center;
		gap: 10px;
		margin-top: 4px;
	}
	.toggle-row span { font-size: 13px; color: var(--body); }
	.toggle {
		position: relative;
		display: inline-block;
		width: 36px;
		height: 20px;
	}
	.toggle input { opacity: 0; width: 0; height: 0; }
	.slider {
		position: absolute;
		cursor: pointer;
		top: 0; left: 0; right: 0; bottom: 0;
		background: var(--hairline-strong);
		border-radius: 20px;
		transition: 0.2s;
	}
	.slider::before {
		content: '';
		position: absolute;
		height: 16px; width: 16px;
		left: 2px; bottom: 2px;
		background: white;
		border-radius: 50%;
		transition: 0.2s;
	}
	.toggle input:checked + .slider { background: var(--primary); }
	.toggle input:checked + .slider::before { transform: translateX(16px); }
	#mainLayout {
		display: flex;
		flex: 1;
		overflow: hidden;
	}
	#sidebar {
		width: 280px;
		flex-shrink: 0;
		background: var(--canvas);
		border-right: 1px solid var(--hairline);
		padding: 16px;
		overflow-y: auto;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}
	.sidebar-section h3 {
		font-size: 12px;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.5px;
		color: var(--mute);
		margin: 0 0 8px;
		font-family: 'JetBrains Mono', monospace;
	}
	.sidebar-hint {
		font-size: 13px;
		color: var(--body);
		margin: 0;
		line-height: 1.5;
	}
	.upload-label {
		display: flex;
		align-items: center;
		gap: 8px;
		padding: 10px 12px;
		border: 1px dashed var(--hairline-strong);
		border-radius: var(--radius-sm);
		cursor: pointer;
		font-size: 13px;
		color: var(--body);
		transition: all 0.15s;
	}
	.upload-label:hover {
		border-color: var(--link);
		color: var(--link);
		background: #f0f7ff;
	}
	.upload-label input { display: none; }
	.file-status {
		font-size: 12px;
		color: var(--success);
		margin-top: 4px;
	}
	.btn-link {
		background: none;
		border: none;
		color: var(--error);
		font-size: 12px;
		cursor: pointer;
		padding: 2px 0;
	}
	.btn-link.hidden { display: none; }
	.sidebar-tips { border-top: 1px solid var(--hairline); padding-top: 16px; }
	.tip-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
	}
	.chip {
		font-size: 12px;
		padding: 5px 10px;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-pill);
		background: var(--canvas);
		color: var(--body);
		cursor: pointer;
		transition: all 0.15s;
		font-family: inherit;
	}
	.chip:hover {
		border-color: var(--ink);
		color: var(--ink);
		background: var(--canvas-soft);
	}
	#chatArea {
		flex: 1;
		display: flex;
		flex-direction: column;
		overflow: hidden;
		background: var(--canvas-soft);
	}
	#messages {
		flex: 1;
		overflow-y: auto;
		padding: 20px;
		display: flex;
		flex-direction: column;
		gap: 16px;
	}
	.message {
		display: flex;
		gap: 12px;
		max-width: 800px;
		animation: fadeIn 0.2s ease;
	}
	@keyframes fadeIn {
		from { opacity: 0; transform: translateY(8px); }
		to { opacity: 1; transform: translateY(0); }
	}
	.message.user { align-self: flex-end; flex-direction: row-reverse; }
	.msg-avatar {
		width: 32px;
		height: 32px;
		border-radius: 9999px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	.message.assistant .msg-avatar {
		background: var(--primary);
		color: var(--on-primary);
	}
	.message.user .msg-avatar {
		background: var(--canvas-soft-2);
		color: var(--body);
	}
	.msg-content {
		background: var(--canvas);
		border: 1px solid var(--hairline);
		border-radius: var(--radius-lg);
		padding: 14px 18px;
		font-size: 14px;
		line-height: 1.6;
		color: var(--ink);
		overflow-x: auto;
	}
	.message.user .msg-content {
		background: var(--primary);
		color: var(--on-primary);
		border-color: var(--primary);
	}
	.msg-content p { margin: 0 0 8px; }
	.msg-content p:last-child { margin: 0; }
	.msg-content strong { font-weight: 600; }
	.msg-content ul, .msg-content ol { margin: 6px 0; padding-left: 20px; }
	.msg-content li { margin: 3px 0; }
	.msg-content hr { border: none; border-top: 1px solid var(--hairline); margin: 12px 0; }
	.msg-content blockquote {
		border-left: 3px solid var(--link);
		margin: 8px 0;
		padding: 4px 12px;
		color: var(--body);
		font-style: italic;
	}
	.message.user .msg-content blockquote {
		border-left-color: rgba(255,255,255,0.4);
		color: rgba(255,255,255,0.85);
	}
	.section-label {
		font-family: 'JetBrains Mono', monospace;
		font-size: 12px;
		font-weight: 600;
		color: var(--mute);
		text-transform: uppercase;
		letter-spacing: 0.5px;
		margin: 14px 0 4px;
	}
	.message.user .section-label { color: rgba(255,255,255,0.6); }
	.section-text { margin: 0; }
	.msg-actions {
		display: flex;
		gap: 6px;
		margin-top: 10px;
	}
	.msg-action-btn {
		background: none;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-sm);
		padding: 4px 8px;
		font-size: 11px;
		color: var(--mute);
		cursor: pointer;
		display: flex;
		align-items: center;
		gap: 4px;
		transition: all 0.15s;
	}
	.msg-action-btn:hover { color: var(--ink); border-color: var(--hairline-strong); }
	.message.interrupted { opacity: 0.7; }
	.message.interrupted .msg-content { border-color: var(--hairline-strong); background: var(--canvas-soft); }
	.streaming-cursor {
		display: inline-block;
		animation: blink 0.8s step-end infinite;
		color: var(--mute);
		font-weight: 300;
		font-size: 16px;
	}
	@keyframes blink {
		50% { opacity: 0; }
	}
	.typing-indicator {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 8px 20px;
	}
	.typing-indicator.hidden { display: none; }
	.typing-indicator span {
		width: 7px; height: 7px;
		border-radius: 50%;
		background: var(--hairline-strong);
		animation: bounce 1.2s infinite;
	}
	.typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
	.typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
	@keyframes bounce {
		0%, 60%, 100% { transform: translateY(0); }
		30% { transform: translateY(-6px); }
	}
	.typing-text {
		font-size: 12px;
		color: var(--mute);
		margin-left: 4px;
		font-family: 'JetBrains Mono', monospace;
	}
	#inputArea {
		display: flex;
		align-items: flex-end;
		gap: 8px;
		padding: 12px 20px 16px;
		background: var(--canvas);
		border-top: 1px solid var(--hairline);
	}
	#questionInput {
		flex: 1;
		border: 1px solid var(--hairline);
		border-radius: var(--radius-md);
		padding: 10px 14px;
		font-size: 14px;
		font-family: inherit;
		line-height: 1.4;
		resize: none;
		outline: none;
		background: var(--canvas-soft);
		color: var(--ink);
		max-height: 120px;
		min-height: 42px;
	}
	#questionInput:focus { border-color: var(--ink); }
	#questionInput::placeholder { color: var(--mute); }
	#micGroup {
		display: flex;
		align-items: center;
		gap: 6px;
		flex-shrink: 0;
	}
	.mic-btn {
		width: 42px;
		height: 42px;
		flex-shrink: 0;
	}
	.mic-btn.listening {
		background: var(--error);
		color: white;
		border-color: var(--error);
		animation: pulse 1.2s infinite;
	}
	.listening-label {
		font-size: 12px;
		font-weight: 500;
		color: var(--error);
		white-space: nowrap;
		animation: fadeIn 0.2s ease;
	}
	.listening-label.hidden { display: none; }
	@keyframes pulse {
		0%, 100% { box-shadow: 0 0 0 0 rgba(238,0,0,0.4); }
		50% { box-shadow: 0 0 0 8px rgba(238,0,0,0); }
	}
	.btn {
		font-family: inherit;
		cursor: pointer;
		border: none;
		font-weight: 500;
		transition: all 0.15s;
	}
	.btn-primary {
		background: var(--primary);
		color: var(--on-primary);
		border-radius: var(--radius-pill);
	}
	.btn-primary:hover { opacity: 0.85; }
	.btn-primary:disabled { opacity: 0.3; cursor: not-allowed; }
	.btn-secondary {
		background: var(--canvas);
		color: var(--ink);
		border: 1px solid var(--hairline);
		border-radius: var(--radius-sm);
	}
	.btn-secondary:hover { background: var(--canvas-soft-2); }
	.btn-sm { padding: 6px 14px; font-size: 13px; }
	.btn-send {
		width: 42px;
		height: 42px;
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
	}
	@media (max-width: 768px) {
		#sidebar { display: none; }
	}
</style>

<script is:inline>
const API_BASE = 'http://localhost:8000';
let sessionId = 'default';
let isListening = false;
let currentSpeaker = null;
let abortController = null;
let userScrolled = false;

const messagesEl = document.getElementById('messages');
const questionInput = document.getElementById('questionInput');
const sendBtn = document.getElementById('sendBtn');
const typingEl = document.getElementById('typingIndicator');
const micBtn = document.getElementById('micBtn');

messagesEl.addEventListener('scroll', () => {
	const threshold = 80;
	const atBottom = messagesEl.scrollHeight - messagesEl.scrollTop - messagesEl.clientHeight < threshold;
	userScrolled = !atBottom;
});

function scrollToBottom() {
	if (userScrolled) return;
	messagesEl.scrollTop = messagesEl.scrollHeight;
}

function getApiBase() {
	return document.getElementById('apiBaseInput')?.value || API_BASE;
}

function getModel() {
	return document.getElementById('modelSelect')?.value || 'llama-3.3-70b-versatile';
}

function getStyle() {
	return document.getElementById('styleSelect')?.value || 'natural';
}

questionInput.addEventListener('input', () => {
	sendBtn.disabled = !questionInput.value.trim();
	autoResize(questionInput);
});

function autoResize(el) {
	el.style.height = 'auto';
	el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

function handleKeyDown(e) {
	if (e.key === 'Enter' && !e.shiftKey) {
		e.preventDefault();
		sendQuestion();
	}
}

function addMessage(role, content) {
	const div = document.createElement('div');
	div.className = `message ${role}`;

	const avatar = document.createElement('div');
	avatar.className = 'msg-avatar';
	if (role === 'assistant') {
		avatar.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>';
	} else {
		avatar.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>';
	}

	const contentDiv = document.createElement('div');
	contentDiv.className = 'msg-content';
	contentDiv.innerHTML = formatMessage(content);

	div.appendChild(avatar);
	div.appendChild(contentDiv);
	messagesEl.appendChild(div);

	if (role === 'assistant') {
		const actions = document.createElement('div');
		actions.className = 'msg-actions';
		const speakBtn = document.createElement('button');
		speakBtn.className = 'msg-action-btn';
		speakBtn.dataset.speaking = 'false';
		speakBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
		speakBtn.onclick = () => toggleSpeech(speakBtn, content.replace(/<[^>]*>/g, ''));
		actions.appendChild(speakBtn);
		contentDiv.appendChild(actions);
	}
}

function escapeHtml(text) {
	const div = document.createElement('div');
	div.textContent = text;
	return div.innerHTML;
}

function formatMessage(text) {
	let html = escapeHtml(text);
	html = html
		.replace(/^### (.+)$/gm, '<strong>$1</strong>')
		.replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
		.replace(/^Question: (.+)$/gm, '<div class="section-label">Question:</div><div class="section-text">$1</div>')
		.replace(/^Best Answer:(.*)$/gm, '<div class="section-label">Best Answer:</div><div class="section-text">$1</div>')
		.replace(/^🧠 Memory Trigger Points:$/gm, '<div class="section-label" style="margin-top:12px">🧠 Memory Trigger Points:</div>')
		.replace(/^💬 Ways to Personalize:$/gm, '<div class="section-label" style="margin-top:12px">💬 Ways to Personalize:</div>')
		.replace(/^• (.+)$/gm, '<li>$1</li>')
		.replace(/^\d\.\s*(.+)$/gm, '<li>$1</li>')
		.replace(/(<li>.*?<\/li>(\s*<li>.*?<\/li>)*)/g, '<ul>$1</ul>')
		.replace(/\n\n/g, '</p><p>')
		.replace(/\n/g, '<br/>')
		.replace(/<\/ul>\s*<br\/>/g, '</ul>')
		.replace(/<br\/>\s*<ul>/g, '<ul>')
		.replace(/<br\/><\/ul>/g, '</ul>')
		.replace(/<br\/>\s*<li>/g, '<li>');
	return html;
}

function createStreamingBubble() {
	const div = document.createElement('div');
	div.className = 'message assistant';

	const avatar = document.createElement('div');
	avatar.className = 'msg-avatar';
	avatar.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="22"/></svg>';

	const contentDiv = document.createElement('div');
	contentDiv.className = 'msg-content';
	contentDiv.innerHTML = '<span class="streaming-cursor">|</span>';

	div.appendChild(avatar);
	div.appendChild(contentDiv);
	messagesEl.appendChild(div);

	return { wrapper: div, contentEl: contentDiv };
}

function updateStreamingBubble(bubble, text) {
	bubble.contentEl.innerHTML = formatMessage(text) + '<span class="streaming-cursor">|</span>';
	if (!userScrolled) {
		messagesEl.scrollTop = messagesEl.scrollHeight;
	}
}

function finalizeStreamingBubble(bubble, text) {
	bubble.contentEl.innerHTML = formatMessage(text);

	const actions = document.createElement('div');
	actions.className = 'msg-actions';
	const speakBtn = document.createElement('button');
	speakBtn.className = 'msg-action-btn';
	speakBtn.dataset.speaking = 'false';
	speakBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
	speakBtn.onclick = () => toggleSpeech(speakBtn, text.replace(/<[^>]*>/g, ''));
	actions.appendChild(speakBtn);
	bubble.contentEl.appendChild(actions);
}

async function sendQuestion() {
	const text = questionInput.value.trim();
	if (!text) return;

	if (abortController) {
		abortController.abort();
	}
	abortController = new AbortController();
	const signal = abortController.signal;

	questionInput.value = '';
	autoResize(questionInput);

	userScrolled = false;
	addMessage('user', text);
	messagesEl.scrollTop = messagesEl.scrollHeight;

	const bubble = createStreamingBubble();
	messagesEl.scrollTop = messagesEl.scrollHeight;

	try {
		const base = getApiBase();
		const resp = await fetch(`${base}/api/ask`, {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify({
				question: text,
				session_id: sessionId,
				model: getModel(),
				style: getStyle(),
			}),
			signal,
		});

		const reader = resp.body.getReader();
		const decoder = new TextDecoder();
		let buffer = '';
		let fullAnswer = '';

		while (true) {
			const { done, value } = await reader.read();
			if (done) break;

			buffer += decoder.decode(value, { stream: true });
			const lines = buffer.split('\n');
			buffer = lines.pop() || '';

			for (const line of lines) {
				const trimmed = line.trim();
				if (!trimmed.startsWith('data: ')) continue;
				const payload = trimmed.slice(6);
				if (payload === '[DONE]') continue;
				try {
					const parsed = JSON.parse(payload);
					if (parsed.token) {
						fullAnswer += parsed.token;
						updateStreamingBubble(bubble, fullAnswer);
					} else if (parsed.error) {
						updateStreamingBubble(bubble, 'Error: ' + parsed.error);
					}
				} catch (e) { /* skip malformed */ }
			}
		}

		if (fullAnswer) {
			finalizeStreamingBubble(bubble, fullAnswer);
		}
	} catch (err) {
		if (err.name === 'AbortError') {
			abortController = null;
			bubble.wrapper.classList.add('interrupted');
			bubble.contentEl.innerHTML = '<div class="section-label" style="margin-top:0">Interrupted</div><p style="color:var(--mute);font-size:13px;margin:4px 0 0">A new question was asked before this answer finished.</p>';
			return;
		}
		bubble.contentEl.innerHTML = `<p>Connection error: ${escapeHtml(err.message)}. Make sure the backend server is running on port 8000.</p>`;
	}

	abortController = null;
}

function askQuick(text) {
	questionInput.value = text;
	sendBtn.disabled = false;
	sendQuestion();
}

function toggleSpeech(btn, text) {
	if (!window.speechSynthesis) return;
	const isSpeaking = btn.dataset.speaking === 'true';

	if (isSpeaking) {
		window.speechSynthesis.cancel();
		btn.dataset.speaking = 'false';
		btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
		currentSpeaker = null;
		return;
	}

	if (currentSpeaker) {
		currentSpeaker.dataset.speaking = 'false';
		currentSpeaker.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
		window.speechSynthesis.cancel();
	}

	const speech = text.slice(0, 2000);
	const utterance = new SpeechSynthesisUtterance(speech);
	utterance.rate = 1.0;
	utterance.pitch = 1.0;
	utterance.volume = 1.0;

	const voices = window.speechSynthesis.getVoices();
	const preferred = voices.find(v => v.lang.startsWith('en') && v.name.includes('Google'));
	if (preferred) utterance.voice = preferred;

	utterance.onend = () => {
		btn.dataset.speaking = 'false';
		btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M15.54 8.46a5 5 0 0 1 0 7.07"/></svg> Listen';
		currentSpeaker = null;
	};

	window.speechSynthesis.speak(utterance);
	btn.dataset.speaking = 'true';
	btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg> Stop';
	currentSpeaker = btn;
}

async function uploadResume(e) {
	const file = e.target.files[0];
	if (!file) return;
	const formData = new FormData();
	formData.append('file', file);
	formData.append('session_id', sessionId);
	try {
		const base = getApiBase();
		const resp = await fetch(`${base}/api/upload/resume?session_id=${sessionId}`, {
			method: 'POST',
			body: formData,
		});
		const data = await resp.json();
		if (data.status === 'ok') {
			document.getElementById('resumeStatus').textContent = 'Resume uploaded successfully';
			document.getElementById('clearResumeBtn').classList.remove('hidden');
		}
	} catch (err) {
		document.getElementById('resumeStatus').textContent = 'Upload failed';
	}
}

